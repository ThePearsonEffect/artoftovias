    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }
        
        body {
            margin: 0;
            padding: 0;
            background-color: #d4d4d3;
            background-image: url('/api/placeholder/1200/800');
            background-size: cover;
            background-attachment: fixed;
            background-position: center;
            color: #515153;
        }
        
        /* Enhanced header styling */
        header {
            background-color: #204d60;
            color: white;
            padding: 40px 20px; 
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 180px; 
        }
        
        .header-title {
            flex-grow: 1;
            text-align: center;
            font-size: 40px; 
            font-weight: bold;
        }
        
        .header-image {
            width: 140px; 
            height: auto;
            border-radius: 8px;
            margin: 0 15px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }
        
        .side-menu {
            position: fixed;
            right: 0;
            top: 180px; 
            width: 250px;
            height: calc(100vh - 180px);
            background-color: #107370;
            padding: 30px 15px;
            z-index: 100;
            transition: opacity 0.4s, transform 0.4s;
            overflow-y: auto;
        }
        
        .side-menu.hidden {
            opacity: 0;
            transform: translateX(100%);
        }
        
        .menu-toggle {
            position: fixed;
            right: 20px;
            top: 190px;
            background-color: #9d4e2b;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 4px;
            cursor: pointer;
            z-index: 101;
            transition: right 0.4s;
        }
        
        .menu-toggle.active {
            right: 260px;
        }
        
        /* Main content layout adjustments */
        .main-content {
            margin-right: 0;
            padding: 20px;
            transition: margin-right 0.4s;
        }
        
        .main-content.shifted {
            margin-right: 250px;
        }
        
        /* Navigation menu styling */
        .side-menu nav ul {
            list-style-type: none;
            padding: 0;
        }
        
        .side-menu nav li {
            margin-bottom: 15px;
        }
        
        .side-menu nav a {
            color: white;
            text-decoration: none;
            display: block;
            padding: 12px 15px;
            background: #204d60;
            border-radius: 6px;
            transition: all 0.3s ease;
        }
        
        /* Glow effect for tabs and links */
        .side-menu nav a:hover, 
        .tab-links:hover,
        .link:hover,
        .nav-menu a:hover {
            background: #515153;
            box-shadow: 0 0 15px rgba(16, 115, 112, 0.7);
            text-shadow: 0 0 5px rgba(255, 255, 255, 0.5);
            transform: translateY(-2px);
        }
        
        /* Nav menu styling */
        .nav-menu {
            margin-top: 20px;
        }
        
        .nav-menu h3 {
            color: white;
            margin-bottom: 15px;
            padding-left: 5px;
        }
        
        .nav-menu ul {
            list-style-type: none;
            padding: 0;
        }
        
        .nav-menu li {
            margin-bottom: 10px;
        }
        
        .nav-menu a {
            color: white;
            text-decoration: none;
            display: block;
            padding: 10px 15px;
            background: rgba(32, 77, 96, 0.8);
            border-radius: 6px;
            transition: all 0.3s ease;
        }
        
        /* Tab styling with glow effects */
        .tab-titles {
            display: flex;
            margin: 20px 0 40px;
            flex-wrap: wrap;
        }
        
        .tab-links {
            margin-right: 20px;
            font-size: 18px;
            font-weight: 500;
            cursor: pointer;
            position: relative;
            padding: 10px 15px;
            background: #107370;
            color: white;
            border-radius: 6px;
            transition: all 0.3s ease;
        }
        
        .tab-links.active-link {
            background: #9d4e2b;
            box-shadow: 0 0 20px rgba(16, 115, 112, 0.8);
        }
        
        .tab-contents {
            display: none;
        }
        
